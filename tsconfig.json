{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "declaration": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "lib": ["DOM", "ES2015"],
    "module": "commonjs",
    "skipLibCheck": true,
    "strict": false,
    "target": "ES2015"
  },
  "display": "Recommended"
}
